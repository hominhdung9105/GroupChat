<Window x:Class="GroupChat_Client.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Viewer"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#111827"
        SizeToContent="WidthAndHeight" 
        MaxWidth="1200" 
        MaxHeight="900">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Background="#1F2937"
                CornerRadius="16"
                Padding="4"
                BorderBrush="#374151"
                BorderThickness="1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="840" 
                          MaxWidth="1140">
                <Border CornerRadius="12" ClipToBounds="True">
                    <Image x:Name="PreviewImage" Stretch="None"/>
                </Border>
            </ScrollViewer>
        </Border>
        <Button Grid.Row="1"
                x:Name="DownloadButton"
                Width="42"
                Height="42"
                HorizontalAlignment="Right"
                Margin="0,8,0,0"
                Foreground="White"
                Background="#4F46E5"
                Cursor="Hand"
                Click="DownloadButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="21">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE896;"/>
        </Button>
    </Grid>
</Window>