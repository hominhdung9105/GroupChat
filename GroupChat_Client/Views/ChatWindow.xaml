<Window x:Class="GroupChat_Client.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:beh="clr-namespace:GroupChat_Client.Behaviors"
        Title="Group Chat"
        Height="800"
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#2A2A2A"
                CornerRadius="14"
                Padding="18"
                Margin="0,0,0,15">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Back"
                            Height="36"
                            Width="90"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Background="#4F46E5"
                            Foreground="White"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            Command="{Binding BackCommand}"/>

                    <TextBlock Grid.Column="1"
                               Text="Group Chat"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               FontSize="14"
                               Foreground="#BBBBBB"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center">
                        <Run Text="Username: "/>
                        <Run Text="{Binding Username, Mode=OneWay}"/>
                    </TextBlock>

                    <TextBlock Grid.Column="1"
                               FontSize="14"
                               Foreground="#BBBBBB"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center">
                        <Run Text="IP: "/>
                        <Run Text="{Binding ServerIp, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#2A2A2A"
                CornerRadius="14"
                Padding="15"
                Margin="0,0,0,15">

            <ListBox ItemsSource="{Binding Messages}"
                     beh:ListBoxScrollBehavior.AutoScroll="True"
                     Background="#2A2A2A"
                     BorderThickness="0"
                     Foreground="White">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="{Binding Sender}"
                                       FontWeight="Bold"
                                       Foreground="#A5B4FC"/>

                            <emoji:TextBlock Text="{Binding Content}"
                                             Foreground="White"
                                             TextWrapping="Wrap"/>

                            <TextBlock Text="{Binding SentAt, StringFormat=HH:mm}"
                                       Foreground="#888888"
                                       FontSize="11"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Height="45"
                     Padding="10"
                     FontSize="14"
                     Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                     Background="#3A3A3A"
                     Foreground="White"
                     BorderBrush="#555555"
                     BorderThickness="1"
                     Margin="0,0,10,0"
                     AcceptsReturn="True" 
                     TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto"
                     beh:TextBoxEnterBehavior.EnterCommand="{Binding SendCommand}" />

            <Border Grid.Column="1"
                    Height="45"
                    Width="45"
                    Background="#3A3A3A"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    Margin="0,0,10,0">

                <emoji:Picker FontSize="18"
                              Picked="EmojiPicker_Picked" 
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
            </Border>

            <Button Grid.Column="2"
                    Content="Send"
                    Height="45"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#4F46E5"
                    Foreground="White"
                    BorderThickness="0"
                    Command="{Binding SendCommand}"/>
        </Grid>
    </Grid>
</Window>