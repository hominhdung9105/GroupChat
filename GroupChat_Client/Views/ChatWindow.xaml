<Window x:Class="GroupChat_Client.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:beh="clr-namespace:GroupChat_Client.Behaviors"
        xmlns:models="clr-namespace:GroupChat_Client.Models"
        AllowDrop="True"
        PreviewDragOver="ChatWindow_OnPreviewDragOver"
        Drop="ChatWindow_OnDrop"
        Title="Group Chat"
        Height="800"
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#2A2A2A"
                CornerRadius="14"
                Padding="18"
                Margin="0,0,0,15">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Back"
                            Height="36"
                            Width="90"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Background="#4F46E5"
                            Foreground="White"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            Command="{Binding BackCommand}"/>

                    <TextBlock Grid.Column="1"
                               Text="Group Chat"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <Border Grid.Column="2"
                            Background="#3A3A3A"
                            CornerRadius="8"
                            Padding="12,6"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" 
                                       Foreground="#10B981" 
                                       FontSize="14" 
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OnlineCount}" 
                                       Foreground="#10B981" 
                                       FontSize="14" 
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" Online" 
                                       Foreground="#BBBBBB" 
                                       FontSize="14" 
                                       Margin="2,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               FontSize="14"
                               Foreground="#BBBBBB"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center">
                        <Run Text="Username: "/>
                        <Run Text="{Binding Username, Mode=OneWay}"/>
                    </TextBlock>

                    <TextBlock Grid.Column="1"
                               FontSize="14"
                               Foreground="#BBBBBB"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center">
                        <Run Text="IP: "/>
                        <Run Text="{Binding ServerIp, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#2A2A2A"
                CornerRadius="14"
                Padding="15"
                Margin="0,0,0,15">

            <ListBox ItemsSource="{Binding Messages}"
                     beh:ListBoxScrollBehavior.AutoScroll="True"
                     Background="#2A2A2A"
                     BorderThickness="0"
                     Foreground="White">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOwnMessage}" Value="False">
                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,12">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Setter Property="MaxWidth" Value="520"/>
                                    <Setter Property="TextBlock.TextAlignment" Value="Left"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOwnMessage}" Value="False">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="TextBlock.TextAlignment" Value="Right"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="{Binding Sender}"
                                       FontWeight="Bold"
                                       Foreground="#A5B4FC"/>

                            <ContentControl Content="{Binding}">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <emoji:TextBlock Text="{Binding Content}"
                                                                     Foreground="White"
                                                                     TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MessageKind}" Value="{x:Static models:ChatMessageKind.Image}">
                                                <Setter Property="ContentTemplate">
                                                    <Setter.Value>
                                                        <DataTemplate>
                                                            <StackPanel>
                                                                <Image Source="{Binding ImagePath}"
                                                                       Stretch="Uniform"
                                                                       MaxHeight="260"
                                                                       Margin="0,6,0,6"/>
                                                                <ProgressBar Height="6"
                                                                             Maximum="100"
                                                                             Value="{Binding ProgressPercent}"
                                                                             Background="#3A3A3A"
                                                                             Foreground="#4F46E5">
                                                                    <ProgressBar.Style>
                                                                        <Style TargetType="ProgressBar">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding ProgressPercent}" Value="100">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </ProgressBar.Style>
                                                                </ProgressBar>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MessageKind}" Value="{x:Static models:ChatMessageKind.File}">
                                                <Setter Property="ContentTemplate">
                                                    <Setter.Value>
                                                        <DataTemplate>
                                                            <Border Background="#333333"
                                                                    CornerRadius="8"
                                                                    Padding="10"
                                                                    Margin="0,6,0,6">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding FileName}"
                                                                               Foreground="White"
                                                                               FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding FileSizeDisplay}"
                                                                               Foreground="#BBBBBB"
                                                                               FontSize="11"
                                                                               Margin="0,2,0,6"/>
                                                                    <ProgressBar Height="6"
                                                                                 Maximum="100"
                                                                                 Value="{Binding ProgressPercent}"
                                                                                 Background="#3A3A3A"
                                                                                 Foreground="#4F46E5"
                                                                                 Margin="0,0,0,8">
                                                                        <ProgressBar.Style>
                                                                            <Style TargetType="ProgressBar">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding ProgressPercent}" Value="100">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ProgressBar.Style>
                                                                    </ProgressBar>
                                                                    <Button Content="Save As"
                                                                            Width="90"
                                                                            HorizontalAlignment="Left"
                                                                            Command="{Binding DataContext.SaveFileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                            CommandParameter="{Binding}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>

                            <TextBlock Text="{Binding SentAt, StringFormat=HH:mm}"
                                       Foreground="#888888"
                                       FontSize="11"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Height="45"
                     Padding="10"
                     FontSize="14"
                     Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                     Background="#3A3A3A"
                     Foreground="White"
                     BorderBrush="#555555"
                     BorderThickness="1"
                     Margin="0,0,10,0"
                     AcceptsReturn="True" 
                     TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto"
                     beh:TextBoxEnterBehavior.EnterCommand="{Binding SendCommand}" />

            <Button x:Name="btnEmoji"
                    Grid.Column="1"
                    Content="😀"
                    Height="45"
                    Width="45"
                    FontSize="18"
                    Background="#3A3A3A"
                    Foreground="White"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    Margin="0,0,10,0"
                    Command="{Binding EmojiCommand}"/>

            <Button Grid.Column="2"
                    Content="🖼️"
                    Height="45"
                    Width="45"
                    FontSize="16"
                    Background="#3A3A3A"
                    Foreground="White"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    Margin="0,0,10,0"
                    Command="{Binding SendImageCommand}"/>

            <Button Grid.Column="3"
                    Content="📎"
                    Height="45"
                    Width="45"
                    FontSize="16"
                    Background="#3A3A3A"
                    Foreground="White"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    Margin="0,0,10,0"
                    Command="{Binding SendFileCommand}"/>

            <Popup IsOpen="{Binding IsEmojiPickerOpen}" 
                   StaysOpen="False" 
                   PlacementTarget="{Binding ElementName=btnEmoji}" 
                   Placement="Top"
                   AllowsTransparency="True">

                <Border Background="#2A2A2A" 
                        BorderBrush="#555555" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="10" 
                        Width="360" 
                        Margin="0,0,0,5">

                    <TabControl ItemsSource="{Binding GroupedEmojis}" 
                                Background="Transparent" 
                                BorderThickness="0"
                                MaxHeight="280">

                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <ScrollViewer Grid.Row="0" 
                                                  HorizontalScrollBarVisibility="Auto" 
                                                  VerticalScrollBarVisibility="Disabled"
                                                  Margin="0,0,0,5"
                                                  Padding="0,0,0,5">
                                        <StackPanel IsItemsHost="True" Orientation="Horizontal"/>
                                    </ScrollViewer>

                                    <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                                </Grid>
                            </ControlTemplate>
                        </TabControl.Template>

                        <TabControl.ItemContainerStyle>
                            <Style TargetType="TabItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#888888"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Margin" Value="0,0,6,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="12" 
                                                    Padding="12,5">
                                                <ContentPresenter ContentSource="Header" 
                                                                  HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3A3A3A"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#4F46E5"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.ItemContainerStyle>

                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Key}" 
                                           FontSize="11" 
                                           FontWeight="SemiBold"/>
                            </DataTemplate>
                        </TabControl.ItemTemplate>

                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                              HorizontalScrollBarVisibility="Disabled"
                                              Margin="0,5,0,0">

                                    <ItemsControl ItemsSource="{Binding}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding PlacementTarget.DataContext.InsertEmojiCommand, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                        CommandParameter="{Binding Emoji}"
                                                        ToolTip="{Binding Description}" 
                                                        Background="Transparent" 
                                                        BorderThickness="0" 
                                                        Width="38" 
                                                        Height="38" 
                                                        Margin="2" 
                                                        Cursor="Hand">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                            <emoji:TextBlock Text="{Binding Emoji}" 
                                                                                             FontSize="22" 
                                                                                             HorizontalAlignment="Center" 
                                                                                             VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#3A3A3A"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Border>
            </Popup>

            <Button Grid.Column="4"
                    Content="Send"
                    Height="45"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#4F46E5"
                    Foreground="White"
                    BorderThickness="0"
                    Command="{Binding SendCommand}"/>
        </Grid>
    </Grid>
</Window>