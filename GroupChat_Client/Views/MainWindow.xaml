<Window x:Class="GroupChat_Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GroupChat_Client.ViewModels"
        mc:Ignorable="d"
        Title="Group Chat Client"
        Height="700"
        Width="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#111827">

    <Window.DataContext>
        <vm:MainViewModel x:Name="MainViewModel" />
    </Window.DataContext>

    <Grid>
        <Border Width="420"
                Padding="40"
                Background="#1F2937"
                CornerRadius="24"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                BorderBrush="#374151"
                BorderThickness="1">

            <StackPanel>
                <Border Width="60" Height="60" 
                        Background="#4F46E5" 
                        CornerRadius="16" 
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center">
                    <TextBlock Text="💬" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Welcome Back"
                           FontSize="26"
                           FontWeight="Black"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Kết nối đến phòng chat của bạn"
                           FontSize="13"
                           Foreground="#9CA3AF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,35"/>

                <TextBlock Text="Username"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <TextBox Height="44"
                         FontSize="14"
                         Padding="12,10"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Background="#111827"
                         Foreground="White"
                         BorderBrush="#374151"
                         BorderThickness="1.5"
                         SelectionBrush="#6366F1"
                         Margin="0,0,0,20">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Server IP"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBox Height="44"
                                 FontSize="14"
                                 Padding="12,10"
                                 Text="{Binding ServerIp, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#111827"
                                 Foreground="White"
                                 BorderBrush="#374151"
                                 BorderThickness="1.5"
                                 Margin="0">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Port"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBox Height="44"
                                 FontSize="14"
                                 Padding="12,10"
                                 Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#111827"
                                 Foreground="White"
                                 BorderBrush="#374151"
                                 BorderThickness="1.5"
                                 Margin="0">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>
                </Grid>

                <Button Height="46"
                        FontSize="15"
                        FontWeight="Bold"
                        Foreground="White"
                        Cursor="Hand"
                        Command="{Binding ConnectCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="Kết nối ngay"/>
                            <Setter Property="Background" Value="#4F46E5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4338CA"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                    <Setter Property="Content" Value="Đang kết nối..."/>
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Background" Value="#4B5563"/>
                                    <Setter Property="Foreground" Value="#9CA3AF"/>
                                    <Setter Property="Cursor" Value="Wait"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>